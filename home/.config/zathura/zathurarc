#zoom
set zoom-step 5
map <C-n> zoom out
map <C-m> zoom in

#clipboard
#set selection-clipboard clipboard

set incremental-search "true"
set font "JetBrainsMono NF"
set adjust-open "width"
set window-title-basename "true"
set statusbar-basename "true"
set guioptions true

# colors

set default-bg '#1a2023'
set default-fg '#bcc4c9'
set recolor-darkcolor '#bcc4c9'
set recolor-lightcolor '#1a2023'
set highlight-color '#bcc4c9'
set highlight-active-color '#89B7B0'
set inputbar-bg '#1a2023'
set inputbar-fg '#bcc4c9'

set recolor false
map i recolor
map <C-Space> toggle_statusbar
