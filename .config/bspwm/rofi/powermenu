#! /bin/sh

uptime="`uptime -p | sed -e 's/up //g'`"

rofi_cmd() {
	rofi -dmenu \
		-p "Uptime: $uptime" \
		-mesg "Uptime: $uptime" \
		-theme ~/.config/bspwm/rofi/power.rasi
}

chosen=$(printf "вЏ»\nпЂЎ\nпњ…" | rofi_cmd)

#chosen=$(printf "вЏ»\nпЂЎ\nпњ…" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"вЏ»") loginctl poweroff ;;
	"пЂЎ") loginctl reboot ;;
	"пњ…") loginctl kill-session self ;;
	*) exit 1 ;;
esac
