[global]
  monitor = 0
  follow = mouse
  shrink = no
  padding = 10
  horizontal_padding = 10
  
  width = 300
  height = 100
  offset = 10x55
  origin = top-right

  frame_width = 2
  separator_height = 2
  frame_color = "#fbf1c7"
  separator_color = "#fbf1c7"

  sort = no
  font = JetBrainsMono Nerd Font 10
  markup = full
  format = "<b>%s</b>\n%b"
  alignment = center
  show_age_threshold = 60
  word_wrap = yes
  ignore_newline = no
  stack_duplicates = true
  hide_duplicate_count = no
  show_indicators = yes

  icon_position = center
  max_icon_size= 60
  sticky_history = yes
  history_length = 6
  title = Dunst
  class = Dunst
  corner_radius = 18

  mouse_left_click = close_current
  mouse_middle_click = do_action
  mouse_right_click = close_all

[urgency_low]
  background = "#3c383690"
  foreground = "#fbf1c7"
  frame_color = "#fbf1c7"
  timeout = 2

[urgency_normal]
  background = "#3c383690"
  foreground = "#fbf1c7"
  frame_color = "#fbf1c7"
  timeout = 2

[urgency_critical]
  background = "#3c383690"
  foreground = "#fbf1c7"
  frame_color = "#fbf1c7"
  timeout = 4
