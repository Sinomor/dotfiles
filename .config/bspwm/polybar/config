[global/wm]
include-file = $HOME/.config/bspwm/polybar/colors
include-file = $HOME/.config/bspwm/polybar/modules
include-file = $HOME/.config/bspwm/polybar/system


[bar/left]
width = 24.5%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
border-color = ${color.fg}
radius = 18
line-size = 0
offset-x = 0.5%
offset-y = 1%
border-size = 3

font-0 = "JetBrainsMono Nerd Font:size=11;3"

modules-center = time bspwm memory cava cpu


[bar/center]
width = 25%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
border-color = ${color.fg}
radius = 18
offset-x = 37.5%
offset-y = 1%
line-size = 0
border-size = 3

font-0 = "JetBrainsMono Nerd Font:size=11;3"

modules-center = title 

[bar/right]
width = 22%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
border-color = ${color.fg}
radius = 18
offset-x = 77.5%
offset-y = 1%
line-size = 0
border-size = 3

font-0 = "JetBrainsMono Nerd Font:size=11;3"

modules-center = net xkeyboard battery volume brigctl

[bar/tray]
width = 5%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
background = ${color.bg}
foreground = ${color.fg}
border-color = ${color.fg}
radius = 18
offset-x = 71.5%
offset-y = 1%
line-size = 0
border-size = 3

font-0 = "JetBrainsMono Nerd Font:size=11;3"

tray-position = center
tray-background = ${color.bg}
modules-center = void
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
