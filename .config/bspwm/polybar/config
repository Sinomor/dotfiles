[global/wm]
include-file = $HOME/.config/bspwm/polybar/colors
include-file = $HOME/.config/bspwm/polybar/modules
include-file = $HOME/.config/bspwm/polybar/system


[bar/left]
width = 24%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
radius = 0
line-size = 0
offset-x = 0.5%
offset-y = 1%

font-0 = "JetBrainsMono Nerd Font:size=11;3"
font-1 = "waffle:size=14;3"

modules-left = time bspwm cpu cava memory


[bar/center]
width = 25%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
radius = 0
offset-x = 37.5%
offset-y = 1%
line-size = 0

font-0 = "JetBrainsMono Nerd Font:size=11;3"
font-1 = "waffle:size=14;3"

modules-center = title 

[bar/right]
width = 21%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
enable-ipc = false
background = ${color.bg}
foreground = ${color.fg}
radius = 0
offset-x = 78.5%
offset-y = 1%
line-size = 0

font-0 = "JetBrainsMono Nerd Font:size=11;3"
font-1 = "waffle:size=14;3"

modules-right = net xkeyboard battery volume brigctl

[bar/tray]
width = 5%
height = 35
wm-restack = bspwm
bottom = false
fixed-center = true
background = ${color.bg}
foreground = ${color.fg}
radius = 0
offset-x = 72.5%
offset-y = 1%
line-size = 0

font-0 = "JetBrainsMono Nerd Font:size=11;3"
font-1 = "waffle:size=14;3"

tray-position = center
tray-background = ${color.bg}
modules-center = void
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true
